{
  "name": "daily-verb-flow",
  "version": "1.0.0",
  "description": "Daily Verb Flow - İngilizce fiil çekimleri öğrenme sistemi",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:watch": "node --test --watch \"test/**/*.test.js\"",
    "lint": "eslint .",
    "format": "prettier \"{app.js,server.js,routes/**/*.js,services/**/*.js,utils/**/*.js,netlify/functions/**/*.js,test/**/*.js,public/js/**/*.js,package.json,README.md,*.toml,.eslintrc.cjs}\" --ignore-unknown --write",
    "format:check": "prettier \"{app.js,server.js,routes/**/*.js,services/**/*.js,utils/**/*.js,netlify/functions/**/*.js,test/**/*.js,public/js/**/*.js,package.json,README.md,*.toml,.eslintrc.cjs}\" --ignore-unknown --check",
    "check": "npm run lint && npm test && npm run format:check",
    "seed": "node seeds/verbs.js",
    "seed-extra": "node seeds/verbs-extra.js",
    "seed-all": "node seeds/verbs.js && node seeds/verbs-extra.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@netlify/functions": "^5.1.2",
    "@sendgrid/mail": "^8.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "firebase-admin": "^12.3.0",
    "node-cron": "^3.0.3",
    "serverless-http": "^4.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "prettier": "^3.3.3"
  }
}
